#!/usr/bin/env bash
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
nvm use

BRANCH=$(git rev-parse --abbrev-ref HEAD)
REGEX="^(feature|bugfix|hotfix)/PLC-[0-9]+$|^release/[0-9]+\.[0-9]+\.[0-9]+$"

if ! [[ $BRANCH =~ $REGEX ]]; then
  echo "Commit rejected: branch name must match '(feature|bugfix|hotfix)/PLC-NNN' or 'release/X.Y.Z'"
  exit 1
fi

STAGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|md)$')
if [ -n "$STAGED" ]; then
  while IFS= read -r file; do
    pnpm exec prettier --write "$file"
    git add "$file"
  done <<< "$STAGED"
fi

turbo lint typecheck test
